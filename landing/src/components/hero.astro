---
---

<section class="relative overflow-hidden pt-32 pb-20 sm:pt-40 sm:pb-28">
  <!-- Subtle background gradient -->
  <div class="pointer-events-none absolute inset-0 -z-10">
    <div class="absolute top-0 left-1/2 -translate-x-1/2 h-[600px] w-[900px] rounded-full bg-accent/5 blur-3xl"></div>
  </div>

  <div class="mx-auto max-w-5xl px-6 text-center">
    <!-- Eyebrow -->
    <div class="mb-6 inline-flex items-center gap-2 rounded-full border border-border bg-bg-card px-4 py-1.5 text-sm text-text-secondary shadow-sm">
      <svg class="h-4 w-4 text-accent" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
        <path stroke-linecap="round" stroke-linejoin="round" d="M12 18.75a6 6 0 006-6v-1.5m-6 7.5a6 6 0 01-6-6v-1.5m6 7.5v3.75m-3.75 0h7.5M12 15.75a3 3 0 01-3-3V4.5a3 3 0 116 0v8.25a3 3 0 01-3 3z" />
      </svg>
      Local-first voice-to-text companion
    </div>

    <!-- Headline -->
    <h1 class="mx-auto max-w-3xl text-5xl font-bold tracking-tight text-text-primary sm:text-6xl lg:text-7xl">
      Speak anywhere.<br />
      <span class="text-accent">Text everywhere.</span>
    </h1>

    <!-- Subheadline -->
    <p class="mx-auto mt-6 max-w-2xl text-lg text-text-secondary sm:text-xl">
      Hold a hotkey, speak naturally, and AI-polished text appears wherever your cursor is  - all processed locally on your machine.
      <span class="font-medium text-text-primary">No cloud. No account. No friction.</span>
    </p>

    <!-- Download Section -->
    <div class="mt-10 flex flex-col items-center gap-4">
      <div class="relative inline-flex" id="download-group">
        <!-- Primary download button -->
        <a
          id="download-primary"
          href="https://github.com/impulse-studio/loqui/releases/latest"
          class="inline-flex items-center gap-2 rounded-l-xl bg-accent px-6 py-3 text-base font-semibold text-white shadow-lg shadow-accent/25 transition-all hover:bg-accent-hover hover:shadow-xl hover:shadow-accent/30"
        >
          <svg id="download-icon" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" d="M3 16.5v2.25A2.25 2.25 0 005.25 21h13.5A2.25 2.25 0 0021 18.75V16.5M16.5 12L12 16.5m0 0L7.5 12m4.5 4.5V3" />
          </svg>
          <span id="download-label">Download</span>
          <span id="download-version" class="ml-1 rounded-md bg-white/20 px-2 py-0.5 text-xs font-medium"></span>
        </a>

        <!-- Dropdown toggle -->
        <button
          id="download-toggle"
          class="inline-flex items-center rounded-r-xl border-l border-white/20 bg-accent px-3 py-3 text-white transition-all hover:bg-accent-hover"
          aria-label="Other platforms"
          aria-expanded="false"
        >
          <svg class="h-4 w-4 transition-transform" id="download-chevron" fill="none" viewBox="0 0 24 24" stroke-width="2.5" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 8.25l-7.5 7.5-7.5-7.5" />
          </svg>
        </button>

        <!-- Dropdown menu -->
        <div
          id="download-menu"
          class="absolute top-full right-0 left-0 z-10 mt-2 hidden rounded-xl border border-border bg-bg-card p-1.5 shadow-xl"
        >
          <div id="download-options" class="space-y-0.5">
            <!-- Populated by JS -->
          </div>
          <div class="my-1.5 border-t border-border"></div>
          <a
            id="download-all-releases"
            href="https://github.com/impulse-studio/loqui/releases/latest"
            target="_blank"
            rel="noopener noreferrer"
            class="flex items-center gap-2 rounded-lg px-3 py-2 text-sm text-text-secondary hover:bg-bg-secondary hover:text-text-primary transition-colors"
          >
            <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 6H5.25A2.25 2.25 0 003 8.25v10.5A2.25 2.25 0 005.25 21h10.5A2.25 2.25 0 0018 18.75V10.5m-10.5 6L21 3m0 0h-5.25M21 3v5.25" />
            </svg>
            All platforms & releases
          </a>
        </div>
      </div>

      <p class="text-sm text-text-tertiary">
        Available for macOS, Windows, and Linux
      </p>
    </div>

    <!-- App Screenshot -->
    <div class="mx-auto mt-16 max-w-4xl">
      <img
        src="/app-screenshot.png"
        alt="Loqui app dashboard showing transcription activity chart, stats (550 words, 25 transcriptions, ~14min saved), and recent transcripts from Slack, Notion, Mail and VSCodium"
        class="w-full rounded-2xl border border-border drop-shadow-2xl"
      />
    </div>
  </div>
</section>
