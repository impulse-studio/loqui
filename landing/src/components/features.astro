---
const features = [
  {
    title: "Hold-to-Dictate",
    description: "System-wide hotkey works in any app. Press, speak, release  - text appears at your cursor instantly.",
    icon: `<path stroke-linecap="round" stroke-linejoin="round" d="M6.75 7.5l3 2.25-3 2.25m4.5 0h3m-9 8.25h13.5A2.25 2.25 0 0021 18V6a2.25 2.25 0 00-2.25-2.25H5.25A2.25 2.25 0 003 6v12a2.25 2.25 0 002.25 2.25z" />`,
  },
  {
    title: "100% Local Processing",
    description: "Whisper.cpp with Metal GPU acceleration. Your audio never leaves your device  - ever.",
    icon: `<path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75L11.25 15 15 9.75m-3-7.036A11.959 11.959 0 013.598 6 11.99 11.99 0 003 9.749c0 5.592 3.824 10.29 9 11.623 5.176-1.332 9-6.03 9-11.622 0-1.31-.21-2.571-.598-3.751h-.152c-3.196 0-6.1-1.248-8.25-3.285z" />`,
  },
  {
    title: "Smart Text Cleanup",
    description: "Optional LLM refactoring cleans up filler words and structures your text. Use local Qwen3 or bring your own key.",
    icon: `<path stroke-linecap="round" stroke-linejoin="round" d="M9.813 15.904L9 18.75l-.813-2.846a4.5 4.5 0 00-3.09-3.09L2.25 12l2.846-.813a4.5 4.5 0 003.09-3.09L9 5.25l.813 2.846a4.5 4.5 0 003.09 3.09L15.75 12l-2.846.813a4.5 4.5 0 00-3.09 3.09zM18.259 8.715L18 9.75l-.259-1.035a3.375 3.375 0 00-2.455-2.456L14.25 6l1.036-.259a3.375 3.375 0 002.455-2.456L18 2.25l.259 1.035a3.375 3.375 0 002.455 2.456L21.75 6l-1.036.259a3.375 3.375 0 00-2.455 2.456z" />`,
  },
  {
    title: "Context-Aware Profiles",
    description: "Loqui detects which app you're in and adapts the writing style  - casual for Slack, formal for email.",
    icon: `<path stroke-linecap="round" stroke-linejoin="round" d="M15.75 6a3.75 3.75 0 11-7.5 0 3.75 3.75 0 017.5 0zM4.501 20.118a7.5 7.5 0 0114.998 0A17.933 17.933 0 0112 21.75c-2.676 0-5.216-.584-7.499-1.632z" />`,
  },
  {
    title: "Always-On Widget",
    description: "A tiny floating indicator lives on all desktops  - even fullscreen. Audio-reactive bars show recording state.",
    icon: `<path stroke-linecap="round" stroke-linejoin="round" d="M9 17.25v1.007a3 3 0 01-.879 2.122L7.5 21h9l-.621-.621A3 3 0 0115 18.257V17.25m6-12V15a2.25 2.25 0 01-2.25 2.25H5.25A2.25 2.25 0 013 15V5.25m18 0A2.25 2.25 0 0018.75 3H5.25A2.25 2.25 0 003 5.25m18 0V12a2.25 2.25 0 01-2.25 2.25H5.25A2.25 2.25 0 013 12V5.25" />`,
  },
  {
    title: "Full History & Stats",
    description: "Every transcription saved and searchable. Track your dictation habits, time saved, and costs.",
    icon: `<path stroke-linecap="round" stroke-linejoin="round" d="M3 13.125C3 12.504 3.504 12 4.125 12h2.25c.621 0 1.125.504 1.125 1.125v6.75C7.5 20.496 6.996 21 6.375 21h-2.25A1.125 1.125 0 013 19.875v-6.75zM9.75 8.625c0-.621.504-1.125 1.125-1.125h2.25c.621 0 1.125.504 1.125 1.125v11.25c0 .621-.504 1.125-1.125 1.125h-2.25a1.125 1.125 0 01-1.125-1.125V8.625zM16.5 4.125c0-.621.504-1.125 1.125-1.125h2.25C20.496 3 21 3.504 21 4.125v15.75c0 .621-.504 1.125-1.125 1.125h-2.25a1.125 1.125 0 01-1.125-1.125V4.125z" />`,
  },
];
---

<section id="features" class="py-20 sm:py-28">
  <div class="mx-auto max-w-5xl px-6">
    <div class="text-center">
      <h2 class="text-3xl font-bold tracking-tight text-text-primary sm:text-4xl">
        Everything you need to dictate
      </h2>
      <p class="mx-auto mt-4 max-w-2xl text-lg text-text-secondary">
        Loqui handles the entire flow  - from voice capture to polished text  - without leaving your keyboard.
      </p>
    </div>

    <div class="mt-16 grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
      {features.map((feature) => (
        <div class="group rounded-2xl border border-border bg-bg-card p-6 transition-all hover:border-accent/20 hover:shadow-lg hover:shadow-accent/5">
          <div class="mb-4 inline-flex items-center justify-center rounded-xl bg-accent-subtle p-2.5">
            <svg class="h-5 w-5 text-accent" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" set:html={feature.icon} />
          </div>
          <h3 class="text-lg font-semibold text-text-primary">{feature.title}</h3>
          <p class="mt-2 text-sm leading-relaxed text-text-secondary">{feature.description}</p>
        </div>
      ))}
    </div>
  </div>
</section>
