---
const currentYear = new Date().getFullYear();
---

<section class="py-20 sm:py-28">
  <div class="mx-auto max-w-5xl px-6">
    <!-- Final CTA -->
    <div class="mb-20 text-center">
      <h2 class="text-3xl font-bold tracking-tight text-text-primary sm:text-4xl">
        Ready to speak?
      </h2>
      <p class="mx-auto mt-4 max-w-xl text-lg text-text-secondary">
        Download Loqui and start dictating in seconds. Free, private, and open source.
      </p>
      <div class="mt-8">
        <a
          id="footer-download"
          href="https://github.com/impulse-studio/loqui/releases/latest"
          class="inline-flex items-center gap-2 rounded-xl bg-accent px-8 py-3.5 text-base font-semibold text-white shadow-lg shadow-accent/25 transition-all hover:bg-accent-hover hover:shadow-xl hover:shadow-accent/30"
        >
          <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" d="M3 16.5v2.25A2.25 2.25 0 005.25 21h13.5A2.25 2.25 0 0021 18.75V16.5M16.5 12L12 16.5m0 0L7.5 12m4.5 4.5V3" />
          </svg>
          <span id="footer-download-label">Download Loqui</span>
          <span id="footer-download-version" class="ml-1 rounded-md bg-white/20 px-2 py-0.5 text-xs font-medium"></span>
        </a>
      </div>
    </div>

    <!-- Footer -->
    <footer class="flex flex-col items-center gap-6 border-t border-border pt-8 sm:flex-row sm:justify-between">
      <div class="flex items-center gap-2.5">
        <img src="/loqui-icon.svg" alt="Loqui" class="h-6 w-6 rounded-md" loading="lazy" />
        <span class="text-sm text-text-secondary">
          Made by <a href="https://impulselab.ai" target="_blank" rel="noopener noreferrer" class="font-medium text-text-primary hover:text-accent transition-colors">Impulse Lab</a>
        </span>
      </div>

      <div class="flex items-center gap-6">
        <a
          href="https://github.com/impulse-studio/loqui"
          target="_blank"
          rel="noopener noreferrer"
          class="text-sm text-text-tertiary hover:text-text-primary transition-colors"
        >
          GitHub
        </a>
        <a
          href="https://github.com/impulse-studio/loqui/releases"
          target="_blank"
          rel="noopener noreferrer"
          class="text-sm text-text-tertiary hover:text-text-primary transition-colors"
        >
          Releases
        </a>
        <span class="text-sm text-text-tertiary">&copy; {currentYear} Impulse Lab</span>
      </div>
    </footer>
  </div>
</section>
