---
const badges = [
  { label: "No cloud", icon: `<path stroke-linecap="round" stroke-linejoin="round" d="M2.25 15a4.5 4.5 0 004.5 4.5H18a3.75 3.75 0 001.332-7.257 3 3 0 00-3.758-3.848 5.25 5.25 0 00-10.233 2.33A4.502 4.502 0 002.25 15z" /><path stroke-linecap="round" stroke-linejoin="round" d="M18.75 12.75l-3-3m0 0l-3 3m3-3v6" />` },
  { label: "No account", icon: `<path stroke-linecap="round" stroke-linejoin="round" d="M15.75 5.25a3 3 0 013 3m3 0a6 6 0 01-7.029 5.912c-.563-.097-1.159.026-1.563.43L10.5 17.25H8.25v2.25H6v2.25H2.25v-2.818c0-.597.237-1.17.659-1.591l6.499-6.499c.404-.404.527-1 .43-1.563A6 6 0 1121.75 8.25z" />` },
  { label: "No telemetry", icon: `<path stroke-linecap="round" stroke-linejoin="round" d="M3.98 8.223A10.477 10.477 0 001.934 12C3.226 16.338 7.244 19.5 12 19.5c.993 0 1.953-.138 2.863-.395M6.228 6.228A10.45 10.45 0 0112 4.5c4.756 0 8.773 3.162 10.065 7.498a10.523 10.523 0 01-4.293 5.774M6.228 6.228L3 3m3.228 3.228l3.65 3.65m7.894 7.894L21 21m-3.228-3.228l-3.65-3.65m0 0a3 3 0 10-4.243-4.243m4.242 4.242L9.88 9.88" />` },
];
---

<section class="py-20 sm:py-28">
  <div class="mx-auto max-w-5xl px-6">
    <div class="overflow-hidden rounded-3xl border border-border bg-bg-card">
      <div class="grid items-center gap-8 p-8 sm:grid-cols-2 sm:gap-12 sm:p-12">
        <!-- Left: Content -->
        <div>
          <div class="mb-4 inline-flex items-center gap-2 rounded-full bg-success/10 px-3 py-1 text-sm font-medium text-success">
            <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75L11.25 15 15 9.75m-3-7.036A11.959 11.959 0 013.598 6 11.99 11.99 0 003 9.749c0 5.592 3.824 10.29 9 11.623 5.176-1.332 9-6.03 9-11.622 0-1.31-.21-2.571-.598-3.751h-.152c-3.196 0-6.1-1.248-8.25-3.285z" />
            </svg>
            Privacy-first
          </div>

          <h2 class="text-3xl font-bold tracking-tight text-text-primary sm:text-4xl">
            Your voice never leaves your device
          </h2>

          <p class="mt-4 text-text-secondary leading-relaxed">
            Loqui runs Whisper.cpp entirely on your machine with Metal GPU acceleration.
            Speech recognition happens locally  - no servers, no uploads, no data collection.
          </p>

          <p class="mt-3 text-text-secondary leading-relaxed">
            Need AI text cleanup? Use the local Qwen3 model or bring your own API key for OpenAI, Anthropic, or Google.
            <span class="font-medium text-text-primary">Your keys, your choice.</span>
          </p>
        </div>

        <!-- Right: Badges -->
        <div class="flex flex-col gap-4">
          {badges.map((badge) => (
            <div class="flex items-center gap-4 rounded-2xl border border-border bg-bg-primary p-5">
              <div class="flex h-12 w-12 shrink-0 items-center justify-center rounded-xl bg-accent-subtle">
                <svg class="h-6 w-6 text-accent" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" set:html={badge.icon} />
              </div>
              <span class="text-lg font-semibold text-text-primary">{badge.label}</span>
            </div>
          ))}
        </div>
      </div>
    </div>
  </div>
</section>
